{
  "name": "plan-harness-server",
  "version": "1.1.0",
  "description": "Local MCP server for plan-harness plugin — manages plan files and serves dashboard",
  "type": "module",
  "scripts": {
    "start": "node start.js",
    "build": "esbuild src/index.js --bundle --platform=node --format=esm --target=node18 --outfile=dist/index.js",
    "sync": "node scripts/sync-to-cache.mjs",
    "dev": "npm run build && npm run sync",
    "prepare-release": "npm install --no-fund --no-audit && npm run build"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "esbuild": "^0.23.0"
  }
}
